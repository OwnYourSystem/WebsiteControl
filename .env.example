# Copy this file to .env and fill in real values. DO NOT commit .env.
# The .env file is gitignored.

# Your site URL (no trailing slash needed)
WP_SITE_URL=https://ownyoursystem.com

# Your WordPress username (the login name, often NOT your email)
WP_USERNAME=your-wp-username

# An Application Password created in WordPress:
#   wp-admin -> Users -> Profile -> Application Passwords
# Spaces are fine here; the script strips them automatically.
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
